# ── Authentication ─────────────────────────────────────────────────────────────
# Set a strong random value here. All /api/properties/* endpoints require
# the header:  X-API-Key: <value>
# Leave blank to disable auth (local dev only).
API_KEY=change_me_to_a_strong_random_secret

# ── Google Maps ────────────────────────────────────────────────────────────────
# IMPORTANT: Rotate your key at https://console.cloud.google.com if it was
# ever committed to git history.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Mapbox (frontend map tiles) ────────────────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_token

# ── ArcGIS / Regrid (parcel data) ─────────────────────────────────────────────
ARCGIS_API_KEY=your_arcgis_key

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minicpm-v
OLLAMA_TIMEOUT=120

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
MAX_CONCURRENT_JOBS=5

# CORS_ORIGINS — space/comma-free JSON array of allowed origins.
# For local dev, keep as is. For production, set to your actual domain:
#   CORS_ORIGINS=["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Production HTTPS (Caddy) ───────────────────────────────────────────────────
# Set DOMAIN to your public hostname to get automatic Let's Encrypt certificates.
# Leave as "localhost" for local dev (uses Caddy's self-signed local CA).
DOMAIN=localhost
ACME_EMAIL=admin@yourdomain.com
